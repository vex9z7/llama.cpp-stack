# Runtime backend: cpu, vulkan, cuda.
# Target deployment is AMD Vulkan, but cpu is useful for CI/debug and cuda is kept as a portability option.
LLAMA_BACKEND=vulkan

# Host bind for the Go gateway. The gateway listens on container port 8090.
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080

# Optional gateway-specific override. Leave empty to inherit LLAMA_HOST/LLAMA_PORT.
GATEWAY_HOST=
GATEWAY_PORT=

# Model used by make smoke / make probe-api. The first run may lazy-download it.
GATEWAY_SMOKE_MODEL=Open4bits/Qwen3-0.6b-gguf/Q4_K_M

# Worker-agent pool. Plain Compose uses the declared worker services; keep this list in sync.
WORKER_BASE_URLS=http://worker-0:8092,http://worker-1:8092
LLAMA_WORKER_POOL_SIZE=2
LLAMA_EVICTION_POLICY=reject
LLAMA_INSTANCE_START_TIMEOUT_SECONDS=120

# Per-worker llama-server defaults.
LLAMA_WORKER_CTX_SIZE=8192
LLAMA_WORKER_PARALLEL=1
LLAMA_WORKER_THREADS_HTTP=-1
LLAMA_WORKER_N_GPU_LAYERS=999
LLAMA_WORKER_EXTRA_ARGS=
LLAMA_SERVER_BIN=/app/llama-server

# Hugging Face download settings. HF_TOKEN is optional for public models.
HF_ENDPOINT=https://huggingface.co
HF_TOKEN=

# Logging.
LOG_LEVEL=info
LOG_FORMAT=json
