# Copy to .env and edit for your machine/model.

# Prefer pinning an explicit build tag once validated on your host, e.g. server-vulkan-b8637.
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-vulkan

# Host/port exposure. Keep HOST_BIND=127.0.0.1 unless you intentionally expose on LAN/VPN.
HOST_BIND=127.0.0.1
HOST_PORT=8080
LLAMA_PORT=8080

# Model path inside the container. Put your GGUF under ./models on the host.
LLAMA_MODEL=/models/model.gguf
LLAMA_ALIAS=local-llm

# Context and concurrency.
# llama-server total ctx is shared across slots: effective per-request ctx ~= CTX_SIZE / N_PARALLEL.
LLAMA_CTX_SIZE=8192
LLAMA_N_PARALLEL=2
LLAMA_THREADS_HTTP=-1

# GPU offload. 999 means "attempt all layers"; reduce if VRAM is insufficient.
LLAMA_N_GPU_LAYERS=999

# Observability/debug endpoints.
LLAMA_METRICS=1
LLAMA_SLOTS=1

# Optional API key. Leave blank for private/local dev only.
LLAMA_API_KEY=
