# Runtime backend: cpu, vulkan, cuda.
# Target deployment is AMD Vulkan, but cpu is useful for CI/debug and cuda is kept as a portability option.
LLAMA_BACKEND=vulkan

# Host bind for the gateway. The gateway listens on container port 8090.
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080

# Optional gateway-specific override. Leave empty to inherit LLAMA_HOST/LLAMA_PORT.
GATEWAY_HOST=
GATEWAY_PORT=

# Model used by make smoke / make probe-api. The first run may lazy-download it.
GATEWAY_SMOKE_MODEL=Open4bits/Qwen3-0.6b-gguf/Q4_K_M

# Internal llama.cpp router mode service.
LLAMA_ROUTER_URL=http://llama-router:8080
LLAMA_ROUTER_IMAGE=
LLAMA_SERVER_BIN=/app/llama-server
LLAMA_MODELS_PRESET=/models/models-preset.generated.ini
LLAMA_MODELS_MAX=2
LLAMA_MODELS_AUTOLOAD=1
LLAMA_SLEEP_IDLE_SECONDS=0
LLAMA_ROUTER_ARGS=

# Per-model llama-server defaults inherited by child instances via router presets.
LLAMA_ROUTER_CTX_SIZE=8192
LLAMA_ROUTER_PARALLEL=1
LLAMA_ROUTER_THREADS_HTTP=-1
LLAMA_ROUTER_N_GPU_LAYERS=999
LLAMA_ROUTER_EXTRA_ARGS=
LLAMA_ROUTER_RELOAD_TIMEOUT_SECONDS=30


# Hugging Face download settings. HF_TOKEN is optional for public models.
HF_ENDPOINT=https://huggingface.co
HF_TOKEN=

# Logging.
LOG_LEVEL=info
LOG_FORMAT=json
