# Runtime backend: cpu, vulkan, cuda.
# Target deployment is AMD Vulkan, but cpu is useful for CI/debug and cuda is kept as a portability option.
LLAMA_BACKEND=vulkan

# Host bind address and port. Keep 127.0.0.1 for local-only access; use 0.0.0.0 for LAN/VPN testing.
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080


# Model downloader. Default uses a dedicated container, so the host does not need hf/huggingface-cli.
DOWNLOADER_MODE=container
DOWNLOADER_IMAGE=llama-cpp-stack-hf-downloader:local
DOCKER_CMD=docker

# Catalog model id. If set, `make up` downloads it before starting.
LLAMA_MODEL=Qwen/Qwen3-4B-GGUF/Q4_K_M

# GGUF model file under ./models. Defaults to hf/${LLAMA_MODEL}.gguf when LLAMA_MODEL is set.
# LLAMA_MODEL_FILE=hf/Qwen/Qwen3-4B-GGUF/Q4_K_M.gguf

# Logical model name exposed to OpenAI-compatible clients.
LLAMA_ALIAS=local-llm

# Context and concurrency.
# llama-server total ctx is shared across slots: effective per-request ctx ~= CTX_SIZE / N_PARALLEL.
LLAMA_CTX_SIZE=8192
LLAMA_N_PARALLEL=2
LLAMA_THREADS_HTTP=-1

# GPU offload. 999 means "attempt all layers"; reduce if VRAM is insufficient.
LLAMA_N_GPU_LAYERS=999

# Optional extra llama-server args, e.g. "--metrics --slots" if supported by your image/version.
LLAMA_EXTRA_ARGS=

# Optional API key. If your llama-server build supports API key auth, pass the corresponding flag via LLAMA_EXTRA_ARGS.
LLAMA_API_KEY=
