{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vex9z7.github.io/llama.cpp-stack/schemas/json/native-completion-request.schema.json",
  "title": "llama.cpp Native /completion Request",
  "type": "object",
  "additionalProperties": true,
  "required": ["prompt"],
  "properties": {
    "prompt": { "type": "string" },
    "stream": { "type": "boolean" },
    "n_predict": { "type": "integer", "minimum": 1 },
    "temperature": { "type": "number", "minimum": 0 },
    "top_k": { "type": "integer" },
    "top_p": { "type": "number" },
    "stop": { "type": "array", "items": { "type": "string" } },
    "grammar": { "type": "string" },
    "cache_prompt": { "type": "boolean" }
  }
}
