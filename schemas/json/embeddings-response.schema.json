{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vex9z7.github.io/llama.cpp-stack/schemas/json/embeddings-response.schema.json",
  "title": "OpenAI-compatible Embeddings Response",
  "type": "object",
  "additionalProperties": true,
  "required": ["object", "data", "model"],
  "properties": {
    "object": { "type": "string", "examples": ["list"] },
    "model": { "type": "string" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["object", "embedding", "index"],
        "properties": {
          "object": { "type": "string", "examples": ["embedding"] },
          "embedding": {
            "oneOf": [
              { "type": "array", "items": { "type": "number" } },
              { "type": "string" }
            ]
          },
          "index": { "type": "integer" }
        }
      }
    },
    "usage": { "type": "object", "additionalProperties": true }
  }
}
