{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vex9z7.github.io/llama.cpp-stack/schemas/json/models-response.schema.json",
  "title": "OpenAI-compatible Models Response",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "object": { "type": "string", "examples": ["list"] },
    "data": {
      "type": "array",
      "items": { "$ref": "#/$defs/model" }
    },
    "models": {
      "description": "llama.cpp compatibility field also observed in /v1/models responses.",
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "object"],
      "properties": {
        "id": { "type": "string" },
        "object": { "type": "string", "examples": ["model"] },
        "created": { "type": "integer" },
        "owned_by": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "meta": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
