{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vex9z7.github.io/llama.cpp-stack/schemas/json/chat-completion-request.schema.json",
  "title": "llama.cpp OpenAI-compatible Chat Completion Request",
  "type": "object",
  "additionalProperties": true,
  "required": ["model", "messages"],
  "properties": {
    "model": { "type": "string" },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chatMessage" }
    },
    "stream": { "type": "boolean", "default": false },
    "max_tokens": { "type": "integer", "minimum": 1 },
    "max_completion_tokens": { "type": "integer", "minimum": 1 },
    "temperature": { "type": "number", "minimum": 0 },
    "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
    "stop": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "response_format": { "$ref": "#/$defs/responseFormat" },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "tool_choice": {
      "oneOf": [
        { "type": "string", "enum": ["none", "auto", "required"] },
        { "$ref": "#/$defs/toolChoice" }
      ]
    },
    "chat_template_kwargs": {
      "type": "object",
      "description": "llama.cpp extension. For Qwen3, {\"enable_thinking\": false} disables thinking/reasoning generation.",
      "additionalProperties": true,
      "properties": {
        "enable_thinking": { "type": "boolean" }
      }
    },
    "reasoning_format": {
      "type": "string",
      "description": "llama.cpp extension controlling how reasoning tags are parsed/returned. It does not disable thinking by itself."
    }
  },
  "$defs": {
    "chatMessage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role", "content"],
      "properties": {
        "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
        "content": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" },
            { "type": "array", "items": { "type": "object", "additionalProperties": true } }
          ]
        },
        "name": { "type": "string" },
        "tool_call_id": { "type": "string" },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolCall" }
        }
      }
    },
    "responseFormat": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["text", "json_object", "json_schema"] },
        "schema": { "type": "object", "additionalProperties": true },
        "json_schema": { "type": "object", "additionalProperties": true }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "function"],
      "properties": {
        "type": { "type": "string", "enum": ["function"] },
        "function": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "parameters": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "toolChoice": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "function"],
      "properties": {
        "type": { "type": "string", "enum": ["function"] },
        "function": {
          "type": "object",
          "required": ["name"],
          "properties": { "name": { "type": "string" } }
        }
      }
    },
    "toolCall": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["function"] },
        "function": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "arguments": { "type": "string" }
          }
        }
      }
    }
  }
}
